    {"es": "el metro", "en": "underground / subway", "ru": "метро"},
    {"es": "el billete / el boleto", "en": "ticket (Spain / LatAm)", "ru": "билет"},
    {"es": "la estación", "en": "station", "ru": "вокзал / станция"},
    {"es": "el aeropuerto", "en": "airport", "ru": "аэропорт"},
    {"es": "el hotel", "en": "hotel", "ru": "отель / гостиница"},
