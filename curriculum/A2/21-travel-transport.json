  "grammar_notes": [
    "Use 'en' for means of transport: 'en avión', 'en tren', 'en coche'. Exception: 'a pie' (on foot).",
    "Spain says 'coche / billete', most of Latin America 'carro / boleto'. Both correct."
  ],
  "example_phrases": [
    "Viajamos a Italia en avión.",
    "El tren llega a las ocho de la mañana.",
    "Quiero reservar una habitación para dos noches."
